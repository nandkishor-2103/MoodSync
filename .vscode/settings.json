{
  // Workspace-wide editor behavior (VSCode-only; no npm installs required)
  "editor.formatOnSave": true,
  "editor.formatOnPaste": true,
  "editor.formatOnType": false,

  // Inline suggestions (ghost text) + better quick fixes
  "editor.inlineSuggest.enabled": true,
  "editor.suggest.preview": true,
  "editor.quickSuggestions": {
    "other": true,
    "comments": false,
    "strings": true
  },

  // Apply "fixers" on save when available (ESLint extension will use this if installed)
  "editor.codeActionsOnSave": {
    "source.fixAll": "explicit",
    "source.fixAll.eslint": "explicit"
  },

  // If you have Prettier extension installed, prefer it as default formatter
  "editor.defaultFormatter": "esbenp.prettier-vscode",

  // ESLint integration (works only if ESLint extension is installed)
  "eslint.enable": true,
  "eslint.format.enable": true,
  "eslint.validate": ["javascript", "javascriptreact", "typescript", "typescriptreact"],
  "eslint.run": "onType",

  // Keep noise down in JS projects
  "javascript.suggestionActions.enabled": true,
  "typescript.suggestionActions.enabled": true,

  // Consistent line endings
  "files.eol": "\n"
}
